{
    "name": "determined",
    "version": "0.1.0",
    "type": "module",
    "license": "MIT",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "dependencies": {
        "@glideapps/ts-necessities": "^2.4.0",
        "neverthrow": "^8.2.0"
    },
    "devDependencies": {
        "@types/node": "^24.10.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build": "tsup",
        "test": "node --experimental-strip-types --test *.test.ts",
        "typecheck": "tsc",
        "prepublishOnly": "npm run build"
    }
}
